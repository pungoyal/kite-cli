# Block lifecycle scripts from dependencies (preinstall/install/postinstall).
# npm v12 defaults this off, but pin it so behaviour does not depend on the
# user's npm version. This is the direct mitigation for the Shai-Hulud worm's
# preinstall vector.
#
# CAVEAT: this also suppresses THIS package's own lifecycle scripts, including
# `prepublishOnly`. A bare `npm publish` from a clean checkout would therefore
# ship without building. Two guards exist:
#   1. Releases go through .github/workflows/release.yml, which runs
#      `npm run build` explicitly and asserts the shebang survived.
#   2. `prepublishOnly` also runs a guard that fails loudly if dist/ is stale,
#      for anyone who publishes by hand with scripts enabled.
# Never publish manually without running `npm run build` first.
ignore-scripts=true

# Do not install a dependency version published within the last day. Compromised
# releases are typically caught within hours, so this filters most incidents at
# the install layer. Measured in days; requires npm >=11.10.0.
min-release-age=1

# Never write package-lock churn from a floating install in CI.
save-exact=false
